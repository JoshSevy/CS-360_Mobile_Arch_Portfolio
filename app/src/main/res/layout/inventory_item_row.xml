<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/inventoryItemRowLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/itemNameTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="@string/item"
        android:textSize="14sp"
        tools:ignore="VisualLintSystemUi" />

    <TextView
        android:id="@+id/itemQuantityTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text=""
        android:textSize="14sp"
        tools:ignore="VisualLintSystemUi" />

    <TextView
        android:id="@+id/itemLocationTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="@string/location"
        android:textSize="14sp"
        tools:ignore="VisualLintSystemUi" />

    <LinearLayout
        android:id="@+id/itemActionsLayout"
        style="?android:attr/buttonBarStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/editItemButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:backgroundTint="@color/instock_primary"
            android:contentDescription="@string/edit_item"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:minEms="0"
            android:padding="0dp"
            android:text="@string/edit"
            android:textColor="@color/white"
            android:textSize="18sp"
            tools:ignore="TouchTargetSizeCheck,VisualLintSystemUi" />

        <Button
            android:id="@+id/deleteItemButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:backgroundTint="@color/instock_delete"
            android:contentDescription="@string/delete_item"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:minEms="0"
            android:padding="0dp"
            android:text="@string/delete_button"
            android:textColor="@color/white"
            android:textSize="18sp"
            tools:ignore="TouchTargetSizeCheck,VisualLintSystemUi" />
    </LinearLayout>
</LinearLayout>